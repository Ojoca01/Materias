    height: 100%;
    div {
        span {
            display: flex;
            align-items: center;
            p:first-child {
                display: none;
            }
            p:last-child:not(:first-child) {
                white-space: nowrap;
            }
        }
        span:first-child:not(:last-child) {
            p {
                font-family: Zona Pro;
                font-size: 50px;
                font-weight: 800;
                line-height: 54px;
                letter-spacing: 0em;
                text-align: left;
                color: #eb565a;
            }
        }
        span:last-child:not(:first-child) {
            p:last-child:not(:first-child)::before {
                content: '(';
            }
            p:last-child:not(:first-child)::after {
                content: ')';
            }
            p:last-child:not(:first-child) {
                font-family: Zona Pro;
                font-size: 18px;
                font-weight: 800;
                line-height: 22px;
                letter-spacing: 0em;
                text-align: left;
                color: #eb565a;
            }
        }
    }
`;Id.div`
    height: 100%;
    div {
        span {
            display: flex;
            align-items: center;
            p:first-child {
                display: none;
            }
            p:last-child:not(:first-child) {
                white-space: nowrap;
            }
        }

        span:last-child:not(:first-child) {
            p:last-child:not(:first-child)::before {
                content: '(';
            }
            p:last-child:not(:first-child)::after {
                content: ')';
            }
            p:last-child:not(:first-child) {
                margin-left: 5px;
            }
        }
    }
`;Id.div`
    div {
        display: flex;
        justify-content: start;
        span {
            display: flex;
            align-items: center;
            p:last-child {
                display: none;
            }
        }
        span:last-child:not(:first-child) {
            display: none;
        }
    }
