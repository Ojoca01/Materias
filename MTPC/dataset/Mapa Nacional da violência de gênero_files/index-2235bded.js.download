`;Id.div`
    div {
        display: flex;
        flex-direction: column;
        span:first-child {
            display: flex;
            flex-direction: row-reverse;
            justify-content: space-between;
        }
        span:last-child {
            display: flex;
            flex-direction: row-reverse;
            justify-content: space-between;
            p:last-child::before {
                content: '(';
            }
            p:last-child::after {
                content: ')';
            }
        }
    }
`;Id.div`
    div {
        display: flex;
        span:first-child {
            display: flex;
            flex-direction: row-reverse;
            justify-content: space-between;
            margin: 5px;
            p:first-child {
                display: none;
            }
        }

        span:last-child {
            display: flex;
            flex-grow: 1;
            flex-direction: row-reverse;
            justify-content: space-between;
            margin: 5px;
            p:last-child {
            }
            p:last-child::before {
                content: '(';
            }
            p:last-child::after {
                content: ')';
            }
        }
    }
`;Id.div`
